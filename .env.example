# Neato Hive — Environment Variables
#
# Claude auth is handled by the CLI — run `claude setup-token` first.
# No API key needed if you're on MAX.

# Each agent gets its own bot token.
# Variable name: DISCORD_BOT_TOKEN_<AGENT_NAME_UPPERCASE>
# Hyphens become underscores: house-md → HOUSE_MD
DISCORD_BOT_TOKEN_HOUSE_MD=

# Your Discord user ID — only you can talk to any agent
DISCORD_OWNER_ID=

# Working directory — where agents operate on projects
WORKING_DIR=/home/user/projects

# Optional model-lane keys — only needed once an agent is assigned a model
# on that lane (config/models.local.yaml or /swap)
#OLLAMA_API_KEY=
#DEEPSEEK_API_KEY=
#GEMINI_API_KEY=
