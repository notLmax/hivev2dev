{
  "name": "neato-hive",
  "version": "2.0.0",
  "description": "Personal AI agent runtime — Claude Agent SDK + Codex MCP + Discord",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hive": "./bin/hive"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:cache": "tsx scripts/cache-acceptance.ts",
    "test:compat": "tsx scripts/compat-live.ts",
    "cache-report": "node scripts/cache-report.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@anthropic-ai/sdk": "^0.104.1",
    "@google/adk": "^1.1.0",
    "better-sqlite3": "^12.10.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  }
